# Alexandria - Variables de entorno
# Copia este archivo como .env y ajusta los valores

# ── Puerto del servidor ──────────────────────────────
ALEXANDRIA_PORT=8080

# ── Proveedor LLM ────────────────────────────────────
# Opciones: "ollama" (offline, por defecto) | "minimax" (cloud)
LLM_PROVIDER=ollama

# ── Configuración Ollama (solo si LLM_PROVIDER=ollama) ──
OLLAMA_BASE=http://localhost:11434

# ── Configuración MiniMax (solo si LLM_PROVIDER=minimax) ─
# Obtén tu API key en: https://www.minimaxi.chat/
MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-M2.7
MINIMAX_BASE=https://api.minimaxi.chat/v1
